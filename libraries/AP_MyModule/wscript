def configure(cfg):
    cfg.env.AP_LIBRARIES.append('AP_MyModule')
    cfg.env.append_value('AP_MODULE_NAMES', 'AP_MyModule')

def build(bld):
    bld.ap_library(
        name='AP_MyModule',
        source=bld.srcnode.ant_glob('*.cpp'),
        includes='.',
        depends=[
            'AP_HAL',
            'AP_Vehicle',
            'AP_Param',
            'AP_Common',
            'AP_Math'
        ],
        install_path='libraries/AP_MyModule',
        cxxflags=['-Wno-unused-parameter']  # 必要に応じて警告抑制
    )
